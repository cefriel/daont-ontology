it6:classification a owl:ObjectProperty ;
    rdfs:label "classification" ;
    rdfs:domain it6:Modality ;
    rdfs:range skos:Concept .

it6:hasInputModality a owl:ObjectProperty ;
    rdfs:label "has input modality" ;
    rdfs:domain mls:Model ;
    rdfs:range it6:Modality .

it6:hasOutputModality a owl:ObjectProperty ;
    rdfs:label "has output modality" ;
    rdfs:domain mls:Model ;
    rdfs:range it6:Modality .

it6:size a owl:DatatypeProperty ;
    rdfs:label "size" .

