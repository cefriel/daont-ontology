<https://w3id.org/daont> a owl:Ontology ;
    rdfs:label "Digital Assets Ontology (DAOnt)" ;
    dcterms:contributor <https://orcid.org/0000-0003-1948-807X>,
        <https://orcid.org/0000-0003-3139-3049> ;
    dcterms:creator <https://orcid.org/0000-0003-1427-3723> ;
    dcterms:description "The Digital Assets Ontology (DAOnt) addresses the digital assets domain, that is, any hardware, software, data, or service that exists in or interacts with a digital ecosystem and provides functional or informational value." ;
    dcterms:issued "2025-10-27" ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:modified "2026-03-27" ;
    dcterms:publisher <https://ror.org/046bfkz44> ;
    dcterms:title "Digital Assets Ontology (DAOnt)" ;
    bibo:status "Draft Ontology"@en ;
    vann:preferredNamespacePrefix "dao" ;
    vann:preferredNamespaceUri "https://w3id.org/daont#" ;
    owl:versionIRI <https://w3id.org/daont/0.0.1> ;
    owl:versionInfo "0.0.1" ;
    schema:citation "Carriero, V.A., Grassi, M., Carenini, A. (2026). Digital Assets Ontology (DAOnt)." ;
    schema:funding <https://doi.org/10.3030/101140087> ;
    mod:createdWith <https://chowlk.linkeddata.es/> .

dao:ClassicalAlgorithm a owl:Class ;
    rdfs:label "Classical Algorithm" ;
    rdfs:subClassOf fabio:Algorithm .

dao:DPU a owl:Class ;
    rdfs:label "D P U" ;
    rdfs:subClassOf devopshw:HardwareItem .

dao:DigitalAsset a owl:Class ;
    rdfs:label "Digital Asset" .

dao:EdgeNode a owl:Class ;
    rdfs:label "Edge Node" ;
    rdfs:subClassOf devopshw:HardwareItem .

dao:Ethernet a owl:NamedIndividual,
        dao:InterfaceTechnology .

dao:HighRisk a owl:NamedIndividual,
        dao:AIActRiskLevel .

dao:LimitedRisk a owl:NamedIndividual,
        dao:AIActRiskLevel .

dao:MinimalRisk a owl:NamedIndividual,
        dao:AIActRiskLevel .

dao:ModelWeights a owl:Class ;
    rdfs:label "Model Weights" .

dao:OWL a owl:NamedIndividual,
        dao:OntologyLanguage .

dao:OperatingSystem a owl:Class ;
    rdfs:label "Operating System" ;
    rdfs:subClassOf devopssw:Software .

dao:PCIexpress a owl:NamedIndividual,
        dao:InterfaceTechnology .

dao:PQCAccelerator a owl:Class ;
    rdfs:label "P Q C Accelerator" ;
    rdfs:subClassOf dao:CryptographicHardwareItem .

dao:PostQuantumCryptographicAlgorithm a owl:Class ;
    rdfs:label "Post Quantum Cryptographic Algorithm" ;
    rdfs:subClassOf dao:CryptographicAlgorithm .

dao:QuantumResistantSecureElement a owl:Class ;
    rdfs:label "Quantum Resistant Secure Element" ;
    rdfs:subClassOf dao:CryptographicHardwareItem .

dao:RDF a owl:NamedIndividual,
        dao:OntologyLanguage .

dao:RDFS a owl:NamedIndividual,
        dao:OntologyLanguage .

dao:Recommended a owl:NamedIndividual,
        dao:RequirementType .

dao:Required a owl:NamedIndividual,
        dao:RequirementType .

dao:SPS a qudt:Unit,
        owl:NamedIndividual .

dao:SignatureAlgorithm a owl:Class ;
    rdfs:label "Signature Algorithm" ;
    rdfs:subClassOf dao:CryptographicAlgorithm .

dao:UnacceptableRisk a owl:NamedIndividual,
        dao:AIActRiskLevel .

dao:VirtualInterface a owl:Class ;
    rdfs:label "Virtual Interface" ;
    rdfs:subClassOf [ a owl:Class ;
            owl:intersectionOf ( devopssw:Software dao:Interface ) ] .

dao:appliesToHardwareType a owl:ObjectProperty ;
    rdfs:label "applies to hardware type" ;
    rdfs:domain dao:Requirement ;
    rdfs:range dao:HardwareType .

dao:appliesToProperty a owl:ObjectProperty ;
    rdfs:label "applies to property" ;
    rdfs:domain dao:Requirement ;
    rdfs:range ssn:Property .

dao:appliesToSoftwareType a owl:ObjectProperty ;
    rdfs:label "applies to software type" ;
    rdfs:domain dao:Requirement ;
    rdfs:range dao:SoftwareType .

dao:availableAtSPARQLEndpoint a owl:DatatypeProperty ;
    rdfs:label "available at s p a r q l endpoint" ;
    rdfs:domain fabio:Ontology ;
    rdfs:range xsd:anyURI .

dao:belongsToCPUFamily a owl:ObjectProperty ;
    rdfs:label "belongs to c p u family" ;
    rdfs:domain dao:CPU ;
    rdfs:range dao:CPUFamily .

