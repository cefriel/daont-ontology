    <owl:Ontology rdf:about="https://w3id.org/daont">
        <owl:versionIRI rdf:resource="https://w3id.org/daont/0.0.1"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-1948-807X"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-3139-3049"/>
        <terms:creator rdf:resource="https://orcid.org/0000-0003-1427-3723"/>
        <terms:description>The Digital Assets Ontology (DAOnt) addresses the digital assets domain, that is, any hardware, software, data, or service that exists in or interacts with a digital ecosystem and provides functional or informational value.</terms:description>
        <terms:issued>2025-10-27</terms:issued>
        <terms:modified>2026-03-27</terms:modified>
        <terms:publisher rdf:resource="https://ror.org/046bfkz44"/>
        <terms:title>Digital Assets Ontology (DAOnt)</terms:title>
        <bibo:status xml:lang="en">Draft Ontology</bibo:status>
        <vann:preferredNamespacePrefix>dao</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>https://w3id.org/daont#</vann:preferredNamespaceUri>
        <rdfs:label>Digital Assets Ontology (DAOnt)</rdfs:label>
        <owl:versionInfo>0.0.1</owl:versionInfo>
        <schema:citation>Carriero, V.A., Grassi, M., Carenini, A. (2026). Digital Assets Ontology (DAOnt).</schema:citation>
        <schema:funding rdf:resource="https://doi.org/10.3030/101140087"/>
        <mod:createdWith rdf:resource="https://chowlk.linkeddata.es/"/>
    </owl:Ontology>
    


