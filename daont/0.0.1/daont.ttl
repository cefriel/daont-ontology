<https://w3id.org/daont> rdf:type owl:Ontology ;
                          owl:versionIRI <https://w3id.org/daont/0.0.1> ;
                          <http://purl.org/dc/terms/contributor> <https://orcid.org/0000-0003-1948-807X> ,
                                                                 <https://orcid.org/0000-0003-3139-3049> ;
                          <http://purl.org/dc/terms/creator> <https://orcid.org/0000-0003-1427-3723> ;
                          <http://purl.org/dc/terms/description> "The Digital Assets Ontology (DAOnt) addresses the digital assets domain, that is, any hardware, software, data, or service that exists in or interacts with a digital ecosystem and provides functional or informational value." ;
                          <http://purl.org/dc/terms/issued> "2025-10-27" ;
                          <http://purl.org/dc/terms/modified> "2026-03-27" ;
                          <http://purl.org/dc/terms/publisher> <https://ror.org/046bfkz44> ;
                          <http://purl.org/dc/terms/title> "Digital Assets Ontology (DAOnt)" ;
                          <http://purl.org/ontology/bibo/status> "Draft Ontology"@en ;
                          <http://purl.org/vocab/vann/preferredNamespacePrefix> "dao" ;
                          <http://purl.org/vocab/vann/preferredNamespaceUri> "https://w3id.org/daont#" ;
                          rdfs:label "Digital Assets Ontology (DAOnt)" ;
                          owl:versionInfo "0.0.1" ;
                          <https://schema.org/citation> "Carriero, V.A., Grassi, M., Carenini, A. (2026). Digital Assets Ontology (DAOnt)." ;
                          <https://schema.org/funding> <https://doi.org/10.3030/101140087> ;
                          <https://w3id.org/mod#createdWith> <https://chowlk.linkeddata.es/> .

